# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://sak100:sak100_secret@localhost:5433/sak100
DATABASE_DIRECT_URL=postgresql://sak100:sak100_secret@localhost:5433/sak100

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379

# Mail
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@sak100.com

# Upload
UPLOAD_PATH=./uploads

# CORS
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Logging
LOG_LEVEL=debug

# Auth
# Development: false = registration immediately activates account (no email verification)
# Production:  true  = requires email verification before account activation
AUTH_REQUIRE_EMAIL_VERIFICATION=false
